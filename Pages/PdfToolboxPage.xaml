<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Toolbox.Pages.PdfToolboxPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="PDF Toolbox" />
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Merge, split, edit, compress, and export PDF files." />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="PDF Files" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    x:Name="AddPdfsButton"
                                    Click="AddPdfsButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="OpenFile" />
                                        <TextBlock Text="Add PDFs" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="ClearPdfsButton"
                                    Grid.Column="1"
                                    Click="ClearPdfsButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="Delete" />
                                        <TextBlock Text="Clear" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <ListView
                                x:Name="PdfListView"
                                MaxHeight="180"
                                SelectionMode="None" />
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Operation" />
                            <ComboBox
                                x:Name="PdfOperationComboBox"
                                Header="Action"
                                SelectedIndex="0"
                                SelectionChanged="PdfOperationComboBox_SelectionChanged">
                                <ComboBoxItem Content="Merge PDFs" />
                                <ComboBoxItem Content="Split every page" />
                                <ComboBoxItem Content="Delete / rotate pages" />
                                <ComboBoxItem Content="Compress PDF" />
                                <ComboBoxItem Content="Export pages to images" />
                            </ComboBox>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="PdfOutputFolderBox"
                                    IsReadOnly="True"
                                    PlaceholderText="Output folder" />
                                <Button
                                    x:Name="ChoosePdfOutputButton"
                                    Grid.Column="1"
                                    Click="ChoosePdfOutputButton_Click">
                                    <SymbolIcon Symbol="Folder" />
                                </Button>
                            </Grid>
                            <TextBox
                                x:Name="PdfOutputNameBox"
                                Header="Output name"
                                PlaceholderText="merged.pdf" />
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="PageEditOptions"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Page Edit" />
                            <TextBox
                                x:Name="DeletePagesBox"
                                Header="Delete pages"
                                PlaceholderText="1, 3-5" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="RotatePagesBox"
                                    Header="Rotate pages"
                                    PlaceholderText="2, 7-9" />
                                <ComboBox
                                    x:Name="RotateDegreesComboBox"
                                    Grid.Column="1"
                                    Header="Degrees"
                                    SelectedIndex="1">
                                    <ComboBoxItem Content="90" />
                                    <ComboBoxItem Content="180" />
                                    <ComboBoxItem Content="270" />
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="RasterOptions"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Raster Options" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <NumberBox
                                    x:Name="PdfDpiBox"
                                    Header="DPI"
                                    Maximum="600"
                                    Minimum="72"
                                    SpinButtonPlacementMode="Inline"
                                    Value="150" />
                                <NumberBox
                                    x:Name="PdfQualityBox"
                                    Grid.Column="1"
                                    Header="Quality"
                                    Maximum="100"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="82" />
                            </Grid>
                            <ComboBox
                                x:Name="PdfImageFormatComboBox"
                                Header="Image format"
                                SelectedIndex="0">
                                <ComboBoxItem Content="JPG" />
                                <ComboBoxItem Content="PNG" />
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Run" />
                        <TextBlock
                            x:Name="PdfSummaryText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="No PDFs selected" />
                    </StackPanel>
                    <Button
                        x:Name="RunPdfToolButton"
                        Grid.Column="1"
                        Click="RunPdfToolButton_Click"
                        IsEnabled="False"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Play" />
                            <TextBlock Text="Run" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border
                    Grid.Row="1"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <TextBox
                        x:Name="PdfLogBox"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        TextWrapping="Wrap"
                        ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </Border>

                <StackPanel Grid.Row="2" Spacing="8">
                    <ProgressBar
                        x:Name="PdfProgressBar"
                        Maximum="100"
                        Minimum="0" />
                    <InfoBar
                        x:Name="PdfInfoBar"
                        IsOpen="False"
                        Severity="Informational" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
