<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Toolbox.Pages.AudioConverterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Audio to MP3" />
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Batch convert audio files to MP3 with quality and output naming controls." />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Audio Files" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    x:Name="AddAudioFilesButton"
                                    Click="AddAudioFilesButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="OpenFile" />
                                        <TextBlock Text="Add files" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="AddAudioFolderButton"
                                    Grid.Column="1"
                                    Click="AddAudioFolderButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="Folder" />
                                        <TextBlock Text="Add folder" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <CheckBox
                                x:Name="AudioIncludeSubfoldersCheckBox"
                                Content="Include subfolders" />
                            <Button
                                x:Name="ClearAudioFilesButton"
                                Click="ClearAudioFilesButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Delete" />
                                    <TextBlock Text="Clear list" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Output" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="AudioOutputFolderBox"
                                    IsReadOnly="True"
                                    PlaceholderText="Output folder" />
                                <Button
                                    x:Name="ChooseAudioOutputButton"
                                    Grid.Column="1"
                                    Click="ChooseAudioOutputButton_Click">
                                    <SymbolIcon Symbol="Folder" />
                                </Button>
                            </Grid>
                            <TextBox
                                x:Name="AudioSuffixBox"
                                Header="Suffix"
                                Text="_mp3"
                                TextChanged="AudioRules_Changed" />
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="MP3 Settings" />
                            <ComboBox
                                x:Name="AudioBitrateComboBox"
                                Header="Bitrate"
                                SelectedIndex="1"
                                SelectionChanged="AudioRules_Changed">
                                <ComboBoxItem Content="128 kbps" />
                                <ComboBoxItem Content="192 kbps" />
                                <ComboBoxItem Content="256 kbps" />
                                <ComboBoxItem Content="320 kbps" />
                            </ComboBox>
                            <ComboBox
                                x:Name="AudioSampleRateComboBox"
                                Header="Sample rate"
                                SelectedIndex="0"
                                SelectionChanged="AudioRules_Changed">
                                <ComboBoxItem Content="Keep source" />
                                <ComboBoxItem Content="44.1 kHz" />
                                <ComboBoxItem Content="48 kHz" />
                            </ComboBox>
                            <ComboBox
                                x:Name="AudioChannelsComboBox"
                                Header="Channels"
                                SelectedIndex="0"
                                SelectionChanged="AudioRules_Changed">
                                <ComboBoxItem Content="Keep source" />
                                <ComboBoxItem Content="Stereo" />
                                <ComboBoxItem Content="Mono" />
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Preview" />
                        <TextBlock
                            x:Name="AudioSummaryText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="No audio files selected" />
                    </StackPanel>
                    <Button
                        x:Name="ConvertAudioButton"
                        Grid.Column="1"
                        Click="ConvertAudioButton_Click"
                        IsEnabled="False"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Play" />
                            <TextBlock Text="Convert" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border
                    Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <ListView
                        x:Name="AudioPreviewListView"
                        SelectionMode="None" />
                </Border>

                <StackPanel Grid.Row="2" Spacing="8">
                    <ProgressBar
                        x:Name="AudioConversionProgressBar"
                        Maximum="100"
                        Minimum="0" />
                    <InfoBar
                        x:Name="AudioConversionInfoBar"
                        IsOpen="False"
                        Severity="Informational" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
