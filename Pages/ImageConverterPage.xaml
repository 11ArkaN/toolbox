<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Toolbox.Pages.ImageConverterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Image Converter" />
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Batch convert images with resize, crop, quality, and suffix rules." />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Images" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    x:Name="AddImagesButton"
                                    Click="AddImagesButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="OpenFile" />
                                        <TextBlock Text="Add images" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="AddImageFolderButton"
                                    Grid.Column="1"
                                    Click="AddImageFolderButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="Folder" />
                                        <TextBlock Text="Add folder" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <CheckBox
                                x:Name="ImageIncludeSubfoldersCheckBox"
                                Content="Include subfolders" />
                            <Button
                                x:Name="ClearImagesButton"
                                Click="ClearImagesButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Delete" />
                                    <TextBlock Text="Clear list" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Output" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="ImageOutputFolderBox"
                                    IsReadOnly="True"
                                    PlaceholderText="Output folder" />
                                <Button
                                    x:Name="ChooseImageOutputButton"
                                    Grid.Column="1"
                                    Click="ChooseImageOutputButton_Click">
                                    <SymbolIcon Symbol="Folder" />
                                </Button>
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox
                                    x:Name="ImageFormatComboBox"
                                    Header="Format"
                                    SelectedIndex="0"
                                    SelectionChanged="ImageRules_Changed">
                                    <ComboBoxItem Content="JPG" />
                                    <ComboBoxItem Content="PNG" />
                                    <ComboBoxItem Content="WebP" />
                                </ComboBox>
                                <TextBox
                                    x:Name="ImageSuffixBox"
                                    Grid.Column="1"
                                    Header="Suffix"
                                    Text="_converted"
                                    TextChanged="ImageRules_Changed" />
                            </Grid>
                            <NumberBox
                                x:Name="ImageQualityBox"
                                Header="Quality"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="ImageRules_Changed" />
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Resize And Crop" />
                            <ComboBox
                                x:Name="ResizeModeComboBox"
                                Header="Resize"
                                SelectedIndex="0"
                                SelectionChanged="ImageRules_Changed">
                                <ComboBoxItem Content="No resize" />
                                <ComboBoxItem Content="Fit inside width/height" />
                                <ComboBoxItem Content="Fill and crop" />
                                <ComboBoxItem Content="Stretch exactly" />
                            </ComboBox>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <NumberBox
                                    x:Name="ImageWidthBox"
                                    Header="Width"
                                    SpinButtonPlacementMode="Inline"
                                    ValueChanged="ImageRules_Changed" />
                                <NumberBox
                                    x:Name="ImageHeightBox"
                                    Grid.Column="1"
                                    Header="Height"
                                    SpinButtonPlacementMode="Inline"
                                    ValueChanged="ImageRules_Changed" />
                            </Grid>
                            <CheckBox
                                x:Name="CropAspectCheckBox"
                                Checked="ImageRules_Changed"
                                Content="Crop to aspect ratio first"
                                Unchecked="ImageRules_Changed" />
                            <ComboBox
                                x:Name="AspectRatioComboBox"
                                Header="Aspect ratio"
                                SelectedIndex="1"
                                SelectionChanged="ImageRules_Changed">
                                <ComboBoxItem Content="1:1" />
                                <ComboBoxItem Content="16:9" />
                                <ComboBoxItem Content="4:3" />
                                <ComboBoxItem Content="3:2" />
                                <ComboBoxItem Content="9:16" />
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Preview" />
                        <TextBlock
                            x:Name="ImageSummaryText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="No images selected" />
                    </StackPanel>
                    <Button
                        x:Name="ConvertImagesButton"
                        Grid.Column="1"
                        Click="ConvertImagesButton_Click"
                        IsEnabled="False"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Play" />
                            <TextBlock Text="Convert" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border
                    Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <ListView
                        x:Name="ImagePreviewListView"
                        SelectionMode="None" />
                </Border>

                <StackPanel Grid.Row="2" Spacing="8">
                    <ProgressBar
                        x:Name="ImageProgressBar"
                        Maximum="100"
                        Minimum="0" />
                    <InfoBar
                        x:Name="ImageInfoBar"
                        IsOpen="False"
                        Severity="Informational" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
