<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Toolbox.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Toolbox"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Toolbox"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="TitleBar"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Image
                Width="18"
                Height="18"
                Margin="16,0,10,0"
                VerticalAlignment="Center"
                Source="/Assets/AppIcon.ico" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Text="Toolbox" />
            <Grid
                x:Name="CustomDragRegion"
                Grid.Column="2" />
            <Grid
                x:Name="CaptionButtonPadding"
                Grid.Column="3" />
        </Grid>

        <NavigationView
            x:Name="Sidebar"
            Grid.Row="1"
            CompactPaneLength="56"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="True"
            IsSettingsVisible="False"
            IsPaneOpen="True"
            OpenPaneLength="224"
            PaneTitle="Tools"
            PaneDisplayMode="Left"
            SelectionChanged="Sidebar_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="AudioNavigationItem"
                    Content="Audio Splitter"
                    Tag="audio">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Audio" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="SlideNavigationItem"
                    Content="Slide Splitter"
                    Tag="slides">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Document" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="RenameNavigationItem"
                    Content="Batch Renamer"
                    Tag="rename">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Edit" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
